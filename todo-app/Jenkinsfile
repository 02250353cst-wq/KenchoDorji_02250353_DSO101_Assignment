pipeline {
    agent any
    
    tools {
        nodejs 'NodeJS-20'
    }
    
    environment {
        // Change these to your actual credentials
        DOCKER_IMAGE_BACKEND = 'your-dockerhub-username/todo-backend'
        DOCKER_IMAGE_FRONTEND = 'your-dockerhub-username/todo-frontend'
        DOCKER_TAG = "${BUILD_NUMBER}"
    }
    
    stages {
        // Stage 1: Checkout code from GitHub
        stage('Checkout') {
            steps {
                git branch: 'main',
                    url: 'https://github.com/yourusername/todo-app.git',
                    credentialsId: 'github-pat'
            }
        }
        
        // Stage 2: Install Backend Dependencies
        stage('Backend Install') {
            steps {
                dir('backend') {
                    sh 'npm install'
                }
            }
        }
        
        // Stage 3: Install Frontend Dependencies
        stage('Frontend Install') {
            steps {
                dir('frontend') {
                    sh 'npm install'
                }
            }
        }
        
        // Stage 4: Run Backend Tests
        stage('Backend Tests') {
            steps {
                dir('backend') {
                    sh 'npm test'
                }
            }
            post {
                always {
                    junit 'backend/junit.xml'
                }
            }
        }
        
        // Stage 5: Build Docker Images
        stage('Build Docker Images') {
            steps {
                script {
                    // Build backend image
                    docker.build("${DOCKER_IMAGE_BACKEND}:${DOCKER_TAG}", "./backend")
                    docker.build("${DOCKER_IMAGE_BACKEND}:latest", "./backend")
                    
                    // Build frontend image
                    docker.build("${DOCKER_IMAGE_FRONTEND}:${DOCKER_TAG}", "./frontend")
                    docker.build("${DOCKER_IMAGE_FRONTEND}:latest", "./frontend")
                }
            }
        }
        
        // Stage 6: Push to Docker Hub
        stage('Push to Docker Hub') {
            steps {
                script {
                    docker.withRegistry('https://registry.hub.docker.com', 'docker-hub-creds') {
                        // Push backend
                        docker.image("${DOCKER_IMAGE_BACKEND}:${DOCKER_TAG}").push()
                        docker.image("${DOCKER_IMAGE_BACKEND}:latest").push()
                        
                        // Push frontend
                        docker.image("${DOCKER_IMAGE_FRONTEND}:${DOCKER_TAG}").push()
                        docker.image("${DOCKER_IMAGE_FRONTEND}:latest").push()
                    }
                }
            }
        }
    }
    
    post {
        success {
            echo '✅ Pipeline completed successfully!'
            echo "Backend image: ${DOCKER_IMAGE_BACKEND}:${DOCKER_TAG}"
            echo "Frontend image: ${DOCKER_IMAGE_FRONTEND}:${DOCKER_TAG}"
        }
        failure {
            echo '❌ Pipeline failed. Check the logs above.'
        }
    }
}