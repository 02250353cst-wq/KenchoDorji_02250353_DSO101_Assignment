pipeline {
    agent any
    
    tools {
        nodejs 'NodeJS-20'
    }
    
    environment {
        DOCKER_IMAGE_BACKEND = 'kenchodorji123/todo-backend'
        DOCKER_IMAGE_FRONTEND = 'kenchodorji123/todo-frontend'
        DOCKER_TAG = "${BUILD_NUMBER}"
        NODE_ENV = 'test'
    }
    
    stages {
        stage('📦 Checkout') {
            steps {
                git branch: 'main',
                    url: 'https://github.com/02250353cst-wq/KenchoDorji_02250353_DSO101_Assignment.git',
                    credentialsId: 'github-credits'  // Fixed here
            }
        }
        
        stage('📥 Backend Install') {
            steps {
                dir('todo-app/backend') {
                    powershell '''
                        Write-Host "Installing backend dependencies..."
                        npm install
                    '''
                }
            }
        }
        
        stage('📥 Frontend Install') {
            steps {
                dir('todo-app/frontend') {
                    powershell '''
                        Write-Host "Installing frontend dependencies..."
                        if (Test-Path "package.json") {
                            npm install
                        } else {
                            Write-Host "No package.json found, skipping..."
                        }
                    '''
                }
            }
        }
        
        stage('🧪 Backend Tests') {
            steps {
                dir('todo-app/backend') {
                    powershell '''
                        Write-Host "Running tests..."
                        npm test
                    '''
                }
            }
            post {
                always {
                    junit 'todo-app/backend/junit.xml'
                }
            }
        }
        
        stage('🐳 Build Backend Image') {
            steps {
                dir('todo-app/backend') {
                    powershell '''
                        docker build -t ${env:DOCKER_IMAGE_BACKEND}:${env:DOCKER_TAG} .
                        docker tag ${env:DOCKER_IMAGE_BACKEND}:${env:DOCKER_TAG} ${env:DOCKER_IMAGE_BACKEND}:latest
                    '''
                }
            }
        }
        
        stage('🐳 Build Frontend Image') {
            steps {
                dir('todo-app/frontend') {
                    powershell '''
                        docker build -t ${env:DOCKER_IMAGE_FRONTEND}:${env:DOCKER_TAG} .
                        docker tag ${env:DOCKER_IMAGE_FRONTEND}:${env:DOCKER_TAG} ${env:DOCKER_IMAGE_FRONTEND}:latest
                    '''
                }
            }
        }
        
        stage('📤 Push to Docker Hub') {
            steps {
                withCredentials([usernamePassword(credentialsId: 'docker-hub-creds', usernameVariable: 'DOCKER_USER', passwordVariable: 'DOCKER_PASS')]) {
                    powershell '''
                        echo ${env:DOCKER_PASS} | docker login -u ${env:DOCKER_USER} --password-stdin
                        docker push ${env:DOCKER_IMAGE_BACKEND}:${env:DOCKER_TAG}
                        docker push ${env:DOCKER_IMAGE_BACKEND}:latest
                        docker push ${env:DOCKER_IMAGE_FRONTEND}:${env:DOCKER_TAG}
                        docker push ${env:DOCKER_IMAGE_FRONTEND}:latest
                    '''
                }
            }
        }
    }
    
    post {
        success {
            echo '🎉 Pipeline successful!'
        }
        failure {
            echo '❌ Pipeline failed'
        }
    }
}